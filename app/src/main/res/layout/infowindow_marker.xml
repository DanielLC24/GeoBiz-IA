<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/glass_surface"
    app:cardCornerRadius="24dp"
    app:cardElevation="14dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/container_simple"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/infowindow_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary_geobiz"
                android:gravity="center"
                android:paddingBottom="8dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/primary_geobiz"
                android:alpha="0.25"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/infowindow_snippet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/on_surface_geobiz"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/container_zone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp"
            android:visibility="gone">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingEnd="96dp">

                    <TextView
                        android:id="@+id/textHeaderZona"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ANÁLISIS DE ZONA"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface_variant_geobiz" />

                    <TextView
                        android:id="@+id/textTituloZona"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Zona Recomendada"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface_geobiz" />
                </LinearLayout>

                <FrameLayout
                    android:layout_width="74dp"
                    android:layout_height="74dp"
                    android:layout_gravity="top|end">

                    <ProgressBar
                        android:id="@+id/progressZonaScore"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:indeterminate="false"
                        android:max="100"
                        android:progress="88"
                        android:progressDrawable="@drawable/bg_circular_progress" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                        android:id="@+id/textZonaScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="87.8"
                        android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface_geobiz" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="/100"
                            android:textSize="10sp"
                            android:textColor="@color/on_surface_variant_geobiz" />
                    </LinearLayout>
                </FrameLayout>
            </FrameLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/glass_surface_secondary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_trending_up"
                            app:tint="@color/on_surface_variant_geobiz" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="TRÁFICO"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface_variant_geobiz" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <ImageView
                                android:id="@+id/iconTraffic1"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_coffee" />
                            <TextView
                                android:id="@+id/textTraffic1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="0"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface_geobiz" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <ImageView
                                android:id="@+id/iconTraffic2"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_martini" />
                            <TextView
                                android:id="@+id/textTraffic2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="0 Bar"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface_geobiz" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_bus" />
                            <TextView
                                android:id="@+id/textTraffic3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="0 Buses"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface_geobiz" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="@color/glass_surface_secondary">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_group" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="COMPETENCIA"
                                android:textAllCaps="true"
                                android:letterSpacing="0.08"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface_variant_geobiz" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/textCompetenciaTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="0"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface_geobiz" />

                        <TextView
                            android:id="@+id/textCompetenciaLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NEGOCIOS"
                            android:textAllCaps="true"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface_variant_geobiz" />

                        <TextView
                            android:id="@+id/textCompetenciaDirecta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="• 0 Directa"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/risk_high" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="@color/glass_surface_secondary">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_bar_chart" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="SOCIOECONÓMICO"
                                android:textAllCaps="true"
                                android:letterSpacing="0.08"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface_variant_geobiz" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/textIndiceSocio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="0.0"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/risk_low" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="INEGI INDEX"
                            android:textAllCaps="true"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface_variant_geobiz" />

                        <TextView
                            android:id="@+id/textNivelSocio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="6dp"
                            android:background="@drawable/bg_nav_item_selected"
                            android:backgroundTint="@color/foda_fortaleza_bg"
                            android:text="NIVEL —"
                            android:textAllCaps="true"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/risk_low" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReporteDetallado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Ver Reporte Detallado"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:paddingVertical="12dp"
                app:cornerRadius="24dp"
                app:icon="@drawable/ic_arrow_forward"
                app:iconPadding="8dp"
                app:backgroundTint="@color/primary_geobiz" />
        </LinearLayout>
    </FrameLayout>
</androidx.cardview.widget.CardView>
