<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="260dp"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/surface_geobiz"
    app:cardCornerRadius="16dp"
    app:cardElevation="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <!-- Título / Recomendación -->
        <TextView
            android:id="@+id/infowindow_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/primary_geobiz"
            android:gravity="center"
            android:paddingBottom="8dp" />

        <!-- Divisor -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/primary_geobiz"
            android:alpha="0.3"
            android:layout_marginBottom="8dp"/>

        <!-- Snippet con todo el detalle -->
        <TextView
            android:id="@+id/infowindow_snippet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/on_surface_geobiz"
            android:lineSpacingExtra="3dp"
            android:visibility="gone" />

    </LinearLayout>
</androidx.cardview.widget.CardView>