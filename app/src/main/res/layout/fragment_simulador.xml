<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background_geobiz">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="8dp">
            <ImageView
                android:id="@+id/btnBackSim"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="12dp"
                android:src="@drawable/ic_back"
                android:contentDescription="@string/accion_atras" />
            <TextView
                android:id="@+id/titleSimulador"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/geobiz_simulador_titulo"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="@color/on_surface_geobiz" />
            <ImageView
                android:id="@+id/btnShareSim"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="12dp"
                android:src="@drawable/ic_share"
                android:contentDescription="@string/accion_compartir" />
        </LinearLayout>

        <!-- ROI Calculado (Anual) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_roi_highlight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/foda_fortaleza_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ROI Calculado (Anual)"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface_geobiz" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">
                    <TextView
                        android:id="@+id/textRoiBig"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="24.5%"
                        android:textSize="34sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface_geobiz" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginStart="10dp">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_trending_up"
                            android:contentDescription="@string/variacion_label"
                            app:tint="@color/risk_low" />
                        <TextView
                            android:id="@+id/textRoiDelta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="+2.1%"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/risk_low" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Meses para Retorno"
                            android:textSize="11sp"
                            android:textColor="@color/on_surface_variant_geobiz" />
                        <TextView
                            android:id="@+id/textMesesRetorno"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="14 meses"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="@color/on_surface_geobiz" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nivel de Riesgo"
                            android:textSize="11sp"
                            android:textColor="@color/on_surface_variant_geobiz" />
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <View
                                android:id="@+id/dotRiesgo"
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@drawable/bg_nav_item_selected"
                                android:backgroundTint="@color/risk_low" />
                            <TextView
                                android:id="@+id/textNivelRiesgo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="BAJO"
                                android:textStyle="bold"
                                android:textSize="16sp"
                                android:textColor="@color/on_surface_geobiz" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Parámetros del Negocio -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Parámetros del Negocio"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface_geobiz" />

        <!-- Renta Mensual -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Renta Mensual"
                android:textSize="14sp"
                android:textColor="@color/on_surface_geobiz" />
            <TextView
                android:id="@+id/textRentaValor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="$2,500"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface_geobiz"
                android:background="@drawable/bg_nav_item_selected"
                android:backgroundTint="@color/surface_geobiz" />
        </LinearLayout>
        <SeekBar
            android:id="@+id/seekRenta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="10" />

        <!-- Inversión Inicial -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Inversión Inicial"
                android:textSize="14sp"
                android:textColor="@color/on_surface_geobiz" />
            <TextView
                android:id="@+id/textInversionValor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="$50,000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface_geobiz"
                android:background="@drawable/bg_nav_item_selected"
                android:backgroundTint="@color/surface_geobiz" />
        </LinearLayout>
        <SeekBar
            android:id="@+id/seekInversion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="20" />

        <!-- Ticket Promedio -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ticket Promedio"
                android:textSize="14sp"
                android:textColor="@color/on_surface_geobiz" />
            <TextView
                android:id="@+id/textTicketValor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="$450"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface_geobiz"
                android:background="@drawable/bg_nav_item_selected"
                android:backgroundTint="@color/surface_geobiz" />
        </LinearLayout>
        <SeekBar
            android:id="@+id/seekTicket"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="40" />

        <!-- Ventas Estimadas -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ventas Estimadas"
                android:textSize="14sp"
                android:textColor="@color/on_surface_geobiz" />
            <TextView
                android:id="@+id/textVentasValor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="120/mes"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface_geobiz"
                android:background="@drawable/bg_nav_item_selected"
                android:backgroundTint="@color/surface_geobiz" />
        </LinearLayout>
        <SeekBar
            android:id="@+id/seekVentas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="30" />

        <!-- Línea de tiempo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="LÍNEA DE TIEMPO DEL RETORNO"
            android:textAllCaps="true"
            android:letterSpacing="0.05"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface_variant_geobiz" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mes 1"
                android:textSize="11sp"
                android:textColor="@color/on_surface_variant_geobiz" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mes 24"
                android:textSize="11sp"
                android:textColor="@color/on_surface_variant_geobiz" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="8dp">
            <View
                android:id="@+id/timelineLine"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="@color/surface_variant_geobiz" />
            <View
                android:id="@+id/dotEquilibrio"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center_vertical"
                android:background="@drawable/bg_nav_item_selected"
                android:backgroundTint="@color/primary_geobiz" />
            <TextView
                android:id="@+id/textPuntoEquilibrioPill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:background="@drawable/bg_nav_item_selected"
                android:backgroundTint="@color/nav_bar_selected_circle"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:text="Punto de Equilibrio"
                android:textColor="@color/on_surface_geobiz"
                android:textSize="11sp" />
            <TextView
                android:id="@+id/textMesEquilibrioNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:text="—"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface_variant_geobiz" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="6dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Inversión" android:textSize="11sp" android:textColor="@color/on_surface_variant_geobiz" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="60dp" android:text="Recuperación" android:textSize="11sp" android:textColor="@color/on_surface_variant_geobiz" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="60dp" android:text="Ganancia" android:textSize="11sp" android:textColor="@color/on_surface_variant_geobiz" />
        </LinearLayout>

        

        <!-- Selección de giro (grid de iconos) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Selecciona tu giro"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface_geobiz" />

        <androidx.gridlayout.widget.GridLayout
            android:id="@+id/grid_categories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:columnCount="3"
            app:rowCount="3"
            app:useDefaultMargins="true">

            <!-- Restaurante -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_restaurante"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_geobiz"
                app:strokeWidth="0dp"
                app:layout_columnWeight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingVertical="14dp"
                    android:paddingHorizontal="8dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_restaurant"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Restaurante"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_geobiz" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Cafetería -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_cafeteria"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_geobiz"
                app:strokeWidth="0dp"
                app:layout_columnWeight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingVertical="14dp"
                    android:paddingHorizontal="8dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_cafe"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Cafetería"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_geobiz" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Taller autos -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_taller"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_geobiz"
                app:strokeWidth="0dp"
                app:layout_columnWeight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingVertical="14dp"
                    android:paddingHorizontal="8dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_car_repair"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Taller autos"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_geobiz" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Farmacia -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_farmacia"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_geobiz"
                app:strokeWidth="0dp"
                app:layout_columnWeight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingVertical="14dp"
                    android:paddingHorizontal="8dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_pharmacy"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Farmacia"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_geobiz" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Papelería -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_papeleria"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_geobiz"
                app:strokeWidth="0dp"
                app:layout_columnWeight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingVertical="14dp"
                    android:paddingHorizontal="8dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_stationery"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Papelería"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_geobiz" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Florería -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_floreria"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_geobiz"
                app:strokeWidth="0dp"
                app:layout_columnWeight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingVertical="14dp"
                    android:paddingHorizontal="8dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_flower"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Florería"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_geobiz" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Personalizado -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_personalizado"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_geobiz"
                app:strokeWidth="0dp"
                app:layout_columnWeight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingVertical="14dp"
                    android:paddingHorizontal="8dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_custom_business"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Personalizado"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_geobiz" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.gridlayout.widget.GridLayout>

        <!-- Panel de parámetros financieros -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_inputs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:visibility="gone"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface_geobiz">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Parámetros financieros"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="@color/on_surface_geobiz" />

                <!-- Renta mensual -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Renta mensual (MXN)"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_geobiz" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    app:boxBackgroundMode="outline">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editRentaMensual"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="$ 20,000"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Inversión inicial -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Inversión inicial (MXN)"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_geobiz" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    app:boxBackgroundMode="outline">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editInversionInicial"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="$ 250,000"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Ticket promedio -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Ticket promedio (MXN)"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_geobiz" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    app:boxBackgroundMode="outline">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editTicketPromedio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="$ 120"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Margen promedio -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Margen promedio (%)"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_geobiz" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    app:boxBackgroundMode="outline">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editMargenPromedio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="35"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Ventas estimadas -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Ventas estimadas (clientes/mes)"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_geobiz" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    app:boxBackgroundMode="outline">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editVentasEstimadas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:hint="600"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Botón ajustes avanzados (solo personalizado) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAjustesAvanzados"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Ajustes avanzados"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Botón principal Calcular ROI -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCalcularRoi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:visibility="gone"
            android:text="Calcular ROI"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:paddingVertical="12dp"
            app:cornerRadius="16dp"
            app:backgroundTint="@color/fab_primary" />

        <!-- Resultados -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_results"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface_geobiz">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/textRoiPorcentaje"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ROI estimado —"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_geobiz" />

                <TextView
                    android:id="@+id/textRoiDetalle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Completa los parámetros para ver el retorno estimado."
                    android:textSize="13sp"
                    android:textColor="@color/on_surface_geobiz" />

                <!-- Semáforo de riesgo -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Nivel de riesgo"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_geobiz" />

                <View
                    android:id="@+id/viewRiesgo"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="6dp"
                    android:background="@color/surface_variant_geobiz" />

                <!-- Comparativa de mercado -->
                <TextView
                    android:id="@+id/textComparativaMercado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="La renta ingresada se comparará con el promedio de la zona BUAP."
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_geobiz" />

                <!-- Dashboard financiero resumido -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Dashboard financiero"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface_geobiz" />

                <TextView
                    android:id="@+id/textIngresosMensuales"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Ingresos mensuales estimados: —"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_geobiz" />

                <TextView
                    android:id="@+id/textPuntoEquilibrio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Punto de equilibrio: —"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_geobiz" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
